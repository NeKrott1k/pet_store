{
    "name": "pet-store/website",
    "description": "Современный интернет-зоомагазин",
    "type": "project",
    "require": {
        "php": ">=8.2.0"
    },
    "require-dev": {
        "vlucas/phpdotenv": "^5.6",
        "symfony/var-dumper": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}